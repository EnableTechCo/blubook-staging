{
  "name": "blubook",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.15.9"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "check": "pnpm lint && pnpm typecheck && pnpm test",
    "supabase": "pnpm dlx supabase@2.109.1",
    "db:types": "pnpm dlx supabase@2.109.1 gen types typescript --linked --schema public > src/types/database.ts",
    "db:types:local": "pnpm dlx supabase@2.109.1 gen types typescript --local --schema public > src/types/database.ts"
  },
  "dependencies": {
    "@supabase/ssr": "0.10.3",
    "@supabase/supabase-js": "2.110.8",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.3.6",
    "@playwright/test": "1.54.1",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.5.2",
    "@types/node": "22.15.3",
    "@types/react": "19.1.5",
    "@types/react-dom": "19.1.5",
    "@vitejs/plugin-react": "4.4.1",
    "autoprefixer": "10.4.21",
    "eslint": "9.26.0",
    "eslint-config-next": "16.2.6",
    "jsdom": "25.0.1",
    "postcss": "8.5.3",
    "tailwindcss": "3.4.17",
    "typescript": "6.0.3",
    "vitest": "3.2.6"
  },
  "pnpm": {
    "overrides": {
      "esbuild": "0.25.0",
      "postcss": "8.5.10"
    }
  }
}
